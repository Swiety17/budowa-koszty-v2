# ── Supabase ──────────────────────────────────────────────────
# Utwórz projekt na https://supabase.com i skopiuj klucze z:
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Anthropic (OCR paragonów) ──────────────────────────────────
# https://console.anthropic.com → API Keys
# Opcjonalne — bez tego OCR nie działa, reszta aplikacji tak

ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail (maile zaproszeniowe + Supabase SMTP) ────────────────
# Wymagane App Password (nie zwykłe hasło):
# Konto Google → Bezpieczeństwo → Weryfikacja dwuetapowa → Hasła do aplikacji

GMAIL_USER=twoj.email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Aplikacja ──────────────────────────────────────────────────
# URL produkcyjny (do linków w emailach)

NEXT_PUBLIC_APP_URL=https://twoja-domena.vercel.app
